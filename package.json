{
  "name": "felaaatelier",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:edge": "next build && opennextjs-cloudflare build --skipBuild",
    "preview": "npm run build:edge && opennextjs-cloudflare preview",
    "deploy:prod": "npm run build:edge && npx wrangler deploy --config wrangler.jsonc --env=\"\"",
    "deploy:staging": "npm run build:edge && npx wrangler deploy --config wrangler.jsonc --env=staging",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "0.487.0",
    "next": "14.2.35",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260217.0",
    "@opennextjs/cloudflare": "1.14.4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "playwright": "^1.60.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.7",
    "typescript": "^5",
    "wrangler": "^4.64.0"
  }
}
